    "import scipy.stats as stats\n",
    "\n",
    "contingency_1 = pd.crosstab(df['version'], df['retention_1'])\n",
    "chi2_1, p_val_1, dof_1, expected_1 = stats.chi2_contingency(contingency_1)\n",
    "\n",
    "print(\"=== 1-Day Retention Chi-Square Test ===\")\n",
    "print(f\"Chi2 Statistic : {chi2_1:.4f}\")\n",
    "print(f\"P-value        : {p_val_1:.4f}\")\n",
    "print(\"-\" * 40)\n",
    "\n",
    "contingency_7 = pd.crosstab(df['version'], df['retention_7'])\n",
    "chi2_7, p_val_7, dof_7, expected_7 = stats.chi2_contingency(contingency_7)\n",
    "\n",
    "print(\"=== 7-Day Retention Chi-Square Test ===\")\n",
    "print(f\"Chi2 Statistic : {chi2_7:.4f}\")\n",
    "print(f\"P-value        : {p_val_7:.4f}\")"
   ]
